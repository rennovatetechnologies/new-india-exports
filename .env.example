# Copy to .env and fill values. Never commit real secrets.
APP_ENV=development
PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/new_india_exports
MONGODB_DB_NAME=new_india_exports
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=24
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
OTP_TTL_MINUTES=10
OTP_RATE_LIMIT=5
MAX_UPLOAD_BYTES=5242880
WORKSHOP_AMOUNT_PAISE=639900
BOOKING_AMOUNT_PAISE=100
